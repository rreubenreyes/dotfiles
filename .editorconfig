# base file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[Makefile]
indent_style = tab

# Work machine only; compatibility with codebase so we don't get weird diffs
[*.{js,jsx,ts,tsx}]
indent_size = 4

[*.py]
indent_size = 4

[*.md]
indent_style = space
indent_size = 2
