# base file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

# Work machine only; compatibility with codebase so we don't get weird diffs
# [*.{js,jsx,ts,tsx}]
# indent_size = 4

[*.py,*.yml,*.yaml]
indent_size = 4

[*.md]
indent_style = space
indent_size = 2

[*.txt]
charset = unset
end_of_line = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset